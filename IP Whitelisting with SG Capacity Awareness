import boto3
import botocore.exceptions  # Import botocore.exceptions
import time

ec2 = boto3.client('ec2')

def lambda_handler(event, context):
    # Access the correct keys from the event dictionary
    instance_id = 'i-zzssxxxxyyyy'  # Correct key access for instance_id
    ip_list = ['5.5.5.5/2', '1.1.1.1/12', '8.8.8.8/32']  # Correct key access for IP list
    port = int("443")  # Correct key access for port
    
    instance = ec2.describe_instances(InstanceIds=[instance_id])['Reservations'][0]['Instances'][0]
    vpc_id = instance['VpcId']
    attached_sgs = [sg['GroupId'] for sg in instance['SecurityGroups']]
    
    # Step 1: Create a set of existing rules to avoid duplication
    existing_rules = set()
    for sg_id in attached_sgs:
        sg_details = ec2.describe_security_groups(GroupIds=[sg_id])['SecurityGroups'][0]
        for perm in sg_details['IpPermissions']:
            if perm['FromPort'] == port and perm['ToPort'] == port:
                for ip_range in perm.get('IpRanges', []):
                    existing_rules.add(ip_range['CidrIp'])
    
    # Filter out IPs that are already present
    filtered_ip_list = [ip for ip in ip_list if ip not in existing_rules]
    
    total_rules_needed = len(filtered_ip_list)
    if total_rules_needed == 0:
        return "No new IPs to add. All IPs are already in existing SGs."

    sg_capacity_needed = (total_rules_needed + 59) // 60
    available_sg_slots = 5 - len(attached_sgs)
    
    # Step 2: Check if there is enough capacity to add all rules
    total_available_slots = 0
    for sg_id in attached_sgs:
        sg_details = ec2.describe_security_groups(GroupIds=[sg_id])['SecurityGroups'][0]
        total_available_slots += (60 - len(sg_details['IpPermissions']))

    if total_available_slots + (available_sg_slots * 60) < total_rules_needed:
        return "Not enough capacity to add all IPs. No changes were made."

    # Step 3: Proceed with adding rules
    ip_index = 0
    sg_counter = 1

    for sg_id in attached_sgs:
        sg_details = ec2.describe_security_groups(GroupIds=[sg_id])['SecurityGroups'][0]
        available_slots = 60 - len(sg_details['IpPermissions'])
        if available_slots > 0:
            rules_to_add = filtered_ip_list[ip_index: ip_index + available_slots]
            add_rules_to_sg(sg_id, rules_to_add, port)
            ip_index += len(rules_to_add)
            if ip_index >= total_rules_needed:
                return f"Added {total_rules_needed} IPs to existing SGs."

    # Create and attach new SGs if necessary
    while ip_index < total_rules_needed and sg_counter <= available_sg_slots:
        new_sg_id = create_new_sg(instance_id, sg_counter, vpc_id)
        attached_sgs.append(new_sg_id)
        sg_counter += 1

        rules_to_add = filtered_ip_list[ip_index: ip_index + 60]
        add_rules_to_sg(new_sg_id, rules_to_add, port)
        ip_index += len(rules_to_add)

    if attached_sgs:
        ec2.modify_instance_attribute(InstanceId=instance_id, Groups=attached_sgs)
        return f"Created and attached new SGs and added {total_rules_needed} IPs."

    return "No changes were made."

def add_rules_to_sg(sg_id, ip_list, port):
    for ip in ip_list:
        try:
            permissions = [{
                'IpProtocol': 'tcp',
                'FromPort': port,
                'ToPort': port,
                'IpRanges': [{'CidrIp': ip}]
            }]
            ec2.authorize_security_group_ingress(GroupId=sg_id, IpPermissions=permissions)
            print(f"Added rule for IP/CIDR: {ip} on port {port} to SG: {sg_id}")
        except botocore.exceptions.ClientError as e:
            print(f"Failed to add rule for IP/CIDR: {ip}. Error: {str(e)}")
            continue

def create_new_sg(instance_id, sg_counter, vpc_id):
    sg_name = f"SG_{instance_id}_whitelist_{sg_counter}_{int(time.time())}"
    new_sg = ec2.create_security_group(GroupName=sg_name, Description='SG for whitelisting IPs', VpcId=vpc_id)
    sg_id = new_sg['GroupId']
    print(f"Created new SG: {sg_id}")
    return sg_id

# Bedrock helpers
# =========================
def _find_first_arn(obj: Any) -> str:
    if isinstance(obj, dict):
        for k, v in obj.items():
            if isinstance(k, str) and ("arn" in k.lower()):
                if isinstance(v, str) and v.startswith("arn:aws:"):
                    return v
            found = _find_first_arn(v)
            if found:
                return found
    elif isinstance(obj, list):
        for item in obj:
            found = _find_first_arn(item)
            if found:
                return found
    return ""

def tag_bedrock_best_effort(clients: dict, evt: dict, tags_kv: Dict[str, str]) -> None:
    arn = ""

    resources = evt.get("resources") or []
    if isinstance(resources, list):
        for r in resources:
            if isinstance(r, dict):
                cand = r.get("ARN") or r.get("arn") or r.get("resourceARN") or r.get("resourceArn")
                if isinstance(cand, str) and cand.startswith("arn:aws:"):
                    arn = cand
                    break

    if not arn:
        arn = _find_first_arn(evt.get("responseElements") or {}) or _find_first_arn(evt)

    if not arn:
        logger.info(f"ℹ️ [Bedrock] No ARN found for {evt.get('eventSource')}:{evt.get('eventName')}; skipping.")
        return

    try:
        # Knowledge Bases live under bedrock:...:knowledge-base/<id>
        # Tagging for KB must go via bedrock-agent TagResource
        if ":knowledge-base/" in arn:
            clients["bedrock_agent"].tag_resource(
                resourceArn=arn,
                tags={k: sanitize_iam_tag_value(v) for k, v in tags_kv.items()},
            )
            logger.info(f"🏷️ [Bedrock KB] tagged {arn}")
            return

        # Everything else stays on bedrock TagResource
        clients["bedrock"].tag_resource(
            resourceARN=arn,
            tags=[{"key": k, "value": sanitize_iam_tag_value(v)} for k, v in tags_kv.items()],
        )
        logger.info(f"🏷️ [Bedrock] tagged {arn}")

    except ClientError as e:
        logger.error(f"❌ [Bedrock] tag_resource failed for {arn}: {e}")


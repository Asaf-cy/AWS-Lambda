def apply_add_only_tags(clients: dict, service: str, rid: str, tags: List[Dict[str, str]], account_id: str) -> None:
    if not rid or not tags:
        return

    try:
        if service == "ec2":
            resp = clients["ec2"].describe_tags(Filters=[{"Name": "resource-id", "Values": [rid]}])
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in (resp.get("Tags") or [])]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["ec2"].create_tags(Resources=[rid], Tags=to_add)

        elif service == "s3":
            try:
                cur = clients["s3"].get_bucket_tagging(Bucket=rid).get("TagSet", []) or []
            except ClientError as e:
                if "NoSuchTagSet" in str(e):
                    cur = []
                elif "NoSuchBucket" in str(e):
                    return
                else:
                    raise
            to_add = enforce_tag_limit(len(cur), filter_add_only(cur, tags))
            if to_add:
                clients["s3"].put_bucket_tagging(Bucket=rid, Tagging={"TagSet": cur + to_add})

        elif service == "rds":
            cur = clients["rds"].list_tags_for_resource(ResourceName=rid).get("TagList", []) or []
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["rds"].add_tags_to_resource(ResourceName=rid, Tags=to_add)

        elif service == "ddb":
            cur = clients["ddb"].list_tags_of_resource(ResourceArn=rid).get("Tags", []) or []
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["ddb"].tag_resource(ResourceArn=rid, Tags=to_add)

        elif service == "kms":
            cur = clients["kms"].list_resource_tags(KeyId=rid).get("Tags", []) or []
            existing = [{"Key": t["TagKey"], "Value": t.get("TagValue", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["kms"].tag_resource(
                    KeyId=rid,
                    Tags=[{"TagKey": t["Key"], "TagValue": t["Value"]} for t in to_add],
                )

        elif service == "cloudfront":
            resp = clients["cloudfront"].list_tags_for_resource(Resource=rid)
            cur = (((resp.get("Tags") or {}).get("Items")) or [])
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["cloudfront"].tag_resource(Resource=rid, Tags={"Items": to_add})

        elif service == "eks":
            cur = clients["eks"].list_tags_for_resource(resourceArn=rid).get("tags", {}) or {}
            if len(cur) < TAG_LIMIT:
                to_add = {t["Key"]: t["Value"] for t in tags if t["Key"] not in cur}
                room = TAG_LIMIT - len(cur)
                to_add = dict(list(to_add.items())[:room])
                if to_add:
                    clients["eks"].tag_resource(resourceArn=rid, tags=to_add)

        elif service == "sns":
            cur = clients["sns"].list_tags_for_resource(ResourceArn=rid).get("Tags", []) or []
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["sns"].tag_resource(ResourceArn=rid, Tags=to_add)

        elif service == "sqs":
            cur = clients["sqs"].list_queue_tags(QueueUrl=rid).get("Tags", {}) or {}
            if len(cur) < TAG_LIMIT:
                to_add = {t["Key"]: t["Value"] for t in tags if t["Key"] not in cur}
                room = TAG_LIMIT - len(cur)
                to_add = dict(list(to_add.items())[:room])
                if to_add:
                    clients["sqs"].tag_queue(QueueUrl=rid, Tags=to_add)

        elif service == "sagemaker":
            cur = clients["sagemaker"].list_tags(ResourceArn=rid).get("Tags", []) or []
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["sagemaker"].add_tags(ResourceArn=rid, Tags=to_add)

        elif service == "autoscaling":
            cur = clients["autoscaling"].describe_tags(
                Filters=[{"Name": "auto-scaling-group", "Values": [rid]}]
            ).get("Tags", []) or []
            existing = [{"Key": t["Key"], "Value": t.get("Value", "")} for t in cur]
            to_add = enforce_tag_limit(len(existing), filter_add_only(existing, tags))
            if to_add:
                clients["autoscaling"].create_or_update_tags(
                    Tags=[
                        {
                            "ResourceId": rid,
                            "ResourceType": "auto-scaling-group",
                            "Key": t["Key"],
                            "Value": t["Value"],
                            "PropagateAtLaunch": True,
                        }
                        for t in to_add
                    ]
                )

    except ClientError as e:
        logger.error(f"❌ [{service}] tagging failed rid={rid}: {e}")

# =========================
# CloudFormation: add-only stack tagging (NEW)
# =========================
def tag_cfn_stack_add_only(cfn_client, stack_id_or_arn: str, tags: List[Dict[str, str]]) -> None:
    """
    Add-only tagging for CloudFormation stacks.
    CloudFormation requires UpdateStack with full tag set (merged).
    """
    if not stack_id_or_arn or not tags:
        return

    try:
        stacks = cfn_client.describe_stacks(StackName=stack_id_or_arn).get("Stacks", []) or []
        if not stacks:
            return

        existing = stacks[0].get("Tags", []) or []
        to_add = filter_add_only(existing, tags)
        to_add = enforce_tag_limit(len(existing), to_add)
        if not to_add:
            return

        merged = existing + to_add

        cfn_client.update_stack(
            StackName=stack_id_or_arn,
            UsePreviousTemplate=True,
            Tags=merged,
            Capabilities=["CAPABILITY_NAMED_IAM", "CAPABILITY_AUTO_EXPAND"],
        )
        logger.info(f"🏷️ [CFN add-only] stack={stack_id_or_arn} -> {to_add}")

    except ClientError as e:
        msg = str(e)
        if "No updates are to be performed" in msg:
            logger.info(f"ℹ️ [CFN] No updates for stack={stack_id_or_arn}")
            return
        logger.error(f"❌ [CFN] update_stack failed stack={stack_id_or_arn}: {e}")

# =========================
# Envelopes (SNS/SQS/S3)
# =========================
def safe_json_loads(s: Any) -> Any:
    if isinstance(s, (dict, list)):
        return s
    try:
        return json.loads(s)
    except Exception:
        return s

def unwrap_sns_if_needed(body: Any) -> Any:
    if isinstance(body, dict) and body.get("Type") == "Notification" and "Message" in body:
        return safe_json_loads(body["Message"])
    return body

def idempotency_key(record: Dict[str, Any]) -> str:
    if "messageId" in record:  # SQS
        raw = record.get("body", "")
        h = hashlib.sha256((raw or "").encode("utf-8")).hexdigest()
        return f"{record['messageId']}:{h}"
    if "Sns" in record:  # SNS
        mid = record["Sns"].get("MessageId", "no-id")
        raw = record["Sns"].get("Message", "")
        h = hashlib.sha256((raw or "").encode("utf-8")).hexdigest()
        return f"{mid}:{h}"
    if "s3" in record:  # direct S3
        key = record["s3"]["object"].get("key", "")
        return f"s3:{hashlib.sha256(key.encode()).hexdigest()}"
    return "unknown"

def s3_records_from_any(record: Dict[str, Any]) -> List[Dict[str, Any]]:
    if "Sns" in record:
        msg = record["Sns"].get("Message", "{}")
        payload = safe_json_loads(msg)
        if isinstance(payload, dict) and "Records" in payload:
            return payload.get("Records") or []
        return []

    if "body" in record:
        body = safe_json_loads(record["body"])
        body = unwrap_sns_if_needed(body)
        if isinstance(body, dict) and "Records" in body:
            return body.get("Records") or []
        if isinstance(body, dict) and "s3" in body:
            return [body]
        return []

    if "s3" in record:
        return [record]

    return []

# =========================
# Core event processing
# =========================
def process_single_cloudtrail_event(clients: dict, evt: dict, account_id: str) -> None:
    if is_failed_event(evt):
        return

    source = evt.get("eventSource") or ""
    event_name = evt.get("eventName") or ""

    # Skip ephemeral EC2 cases but keep CLI/UI/human coverage
    if source == "ec2.amazonaws.com" and event_name == "RunInstances":
        if not should_tag_ec2_instance(evt):
            return

    created_by_raw = _extract_best_actor(evt)
    created_by = sanitize_iam_tag_value(created_by_raw) or "unknown"
    created_time = sanitize_iam_tag_value(evt.get("eventTime", ""))

    base_tags = [
        {"Key": "created_by", "Value": created_by},
        {"Key": "created_time", "Value": created_time},
        {"Key": "autotag", "Value": "true"},
    ]

    # -------------------------
    # CloudFormation stacks (ENABLED)
    # -------------------------
    if source == "cloudformation.amazonaws.com" and event_name in ("CreateStack", "UpdateStack"):
        stack_id = get_path(evt, "responseElements.stackId")
        stack_name = get_path(evt, "requestParameters.stackName")
        target = stack_id or stack_name
        if not target:
            logger.info(f"ℹ️ [CFN] {event_name} missing stack identifier; skipping.")
            return
        tag_cfn_stack_add_only(clients["cloudformation"], target, base_tags)
        return

    # -------------------------
    # IAM: Users / Roles / Keys
    # -------------------------
    if source == "iam.amazonaws.com":
        iam_client = clients["iam"]
        req = evt.get("requestParameters") or {}
        relem = evt.get("responseElements") or {}

        # CreateUser
        if event_name == "CreateUser":
            user_name = ""
            if isinstance(relem, dict):
                u = relem.get("user")
                if isinstance(u, dict):
                    user_name = u.get("userName") or ""
            user_name = user_name or req.get("userName") or ""
            if user_name:
                iam_add_standard_user_tags_add_only(iam_client, user_name, base_tags)
            return

        # CreateRole (add-only)
        if event_name == "CreateRole":
            role_name = ""
            if isinstance(relem, dict):
                r = relem.get("role")
                if isinstance(r, dict):
                    role_name = r.get("roleName") or ""
            role_name = role_name or req.get("roleName") or ""

            role_path = req.get("path") or ""
            if SKIP_SERVICE_LINKED_ROLES and isinstance(role_path, str) and "aws-service-role" in role_path:
                return

            if role_name:
                iam_add_standard_role_tags_add_only(iam_client, role_name, base_tags)
            return

        # TagRole: ensure standard tags exist (add-only), and don't loop on ourselves
        if event_name == "TagRole":
            if is_automation_actor(evt):
                return

            role_name = req.get("roleName") or ""
            if not role_name:
                return

            iam_add_standard_role_tags_add_only(iam_client, role_name, base_tags)
            return

        # CreateAccessKey
        if event_name == "CreateAccessKey":
            access_key_id = ""
            user_name = ""

            if isinstance(relem, dict):
                ak = relem.get("accessKey") or {}
                if isinstance(ak, dict):
                    access_key_id = ak.get("accessKeyId") or ""
                    user_name = ak.get("userName") or ""

            user_name = user_name or req.get("userName") or (evt.get("userIdentity") or {}).get("userName") or ""
            if user_name:
                iam_add_standard_user_tags_add_only(iam_client, user_name, base_tags)
            if user_name and access_key_id:
                iam_append_created_by_for_key_tag(iam_client, user_name, access_key_id, created_by_raw)
            return

        # DeleteAccessKey
        if event_name == "DeleteAccessKey":
            user_name = req.get("userName") or (evt.get("userIdentity") or {}).get("userName") or ""
            access_key_id = req.get("accessKeyId") or ""
            if user_name and access_key_id:
                iam_remove_user_tag_key(iam_client, user_name, access_key_id)
                iam_cleanup_orphan_access_key_tags(iam_client, user_name)
            return

        # CreateServiceSpecificCredential (ACCA...)
        if event_name == "CreateServiceSpecificCredential":
            user_name = req.get("userName") or ""
            cred_id = ""
            if isinstance(relem, dict):
                ssc = relem.get("serviceSpecificCredential") or {}
                if isinstance(ssc, dict):
                    cred_id = ssc.get("serviceSpecificCredentialId") or ""
            if user_name:
                iam_add_standard_user_tags_add_only(iam_client, user_name, base_tags)
            if user_name and cred_id:
                iam_append_created_by_for_key_tag(iam_client, user_name, cred_id, created_by_raw)
            return

        # DeleteServiceSpecificCredential
        if event_name == "DeleteServiceSpecificCredential":
            user_name = req.get("userName") or ""
            cred_id = req.get("serviceSpecificCredentialId") or ""
            if user_name and cred_id:
                iam_remove_user_tag_key(iam_client, user_name, cred_id)
            return

        # TagUser (console sets "Description" on credentials -> TagUser)
        if event_name == "TagUser":
            if is_automation_actor(evt):
                return

            user_name = req.get("userName") or ""
            if not user_name:
                return

            # Ensure standard tags exist (add-only)
            iam_add_standard_user_tags_add_only(iam_client, user_name, base_tags)

            tagged = parse_tags_from_request(req)
            if not tagged:
                return

            # If user tagged the key-id itself (AKIA/ASIA/ACCA), append created_by only
            for t in tagged:
                k = t.get("Key") or ""
                if looks_like_key_tag(k):
                    iam_append_created_by_for_key_tag(iam_client, user_name, k, created_by_raw)
            return

        return  # other IAM events ignored

    # -------------------------
    # Bedrock resources (best effort)
    # -------------------------
    if source in ("bedrock.amazonaws.com", "bedrock-agent.amazonaws.com"):
        tag_bedrock_best_effort(
            clients,
            evt,
            {"created_by": created_by_raw, "created_time": evt.get("eventTime", ""), "autotag": "true"},
        )
        return

    # -------------------------
    # Other mapped services
    # -------------------------
    cfg = RESOURCE_MAPPINGS.get((source, event_name))
    if not cfg:
        return

    ids = extract_resource_ids_for_mapping(evt, account_id=account_id)
    if not ids:
        return

    for rid in ids:
        apply_add_only_tags(clients, cfg["service"], rid, base_tags, account_id=account_id)

def process_s3_record(s3_record: Dict[str, Any]) -> None:
    rec_s3 = s3_record.get("s3") or {}
    obj = rec_s3.get("object") or {}
    key_enc = obj.get("key")
    if not key_enc:
        return

    key = unquote_plus(key_enc)
    if ORG_ID not in key or not key.startswith(S3_EVENT_PREFIX):
        return

    _, account_id, region = extract_account_and_region_from_key(key)
    if not account_id or account_id not in ALLOWED_ACCOUNTS:
        return

    bucket = rec_s3.get("bucket", {}).get("name")
    if not bucket:
        return

    events_iter = iter_relevant_events_via_s3_select(bucket, key)
    if events_iter is None:
        events_iter = iter_relevant_events_streaming(bucket, key)

    clients = None
    for evt in events_iter:
        if clients is None:
            clients = assume_role(account_id, region)
            if not clients:
                raise RuntimeError(f"AssumeRole failed for acct={account_id} region={region}")

        try:
            process_single_cloudtrail_event(clients, evt, account_id=account_id)
        except (ClientError, EndpointConnectionError, ConnectionClosedError, ReadTimeoutError) as e:
            logger.error(f"❌ Tagging failed for {evt.get('eventSource')}:{evt.get('eventName')}: {e}")
        except Exception as e:
            logger.error(f"❌ Unexpected error {evt.get('eventSource')}:{evt.get('eventName')}: {e}")

# =========================
# Top-level record worker
# =========================
def handle_one_top_record(record: Dict[str, Any]) -> Dict[str, Any]:
    key = idempotency_key(record)
    try:
        s3_recs = s3_records_from_any(record)
        if not s3_recs:
            return {"ok": True}

        for s3_rec in s3_recs:
            process_s3_record(s3_rec)

        return {"ok": True}
    except Exception as e:
        reason = f"{type(e).__name__}: {str(e)[:500]}"
        logger.error(f"[{key}] FAIL | {reason}")
        return {"ok": False, "reason": reason}

# =========================
# Lambda entrypoint
# =========================
def lambda_handler(event, context):
    records = event.get("Records", []) or []
    if not records:
        return {"batchItemFailures": []}

    is_sqs = records[0].get("eventSource") == "aws:sqs"
    failures: List[Dict[str, str]] = []

    with concurrent.futures.ThreadPoolExecutor(max_workers=WORKERS) as ex:
        futs = {ex.submit(handle_one_top_record, r): r for r in records}
        for fut in concurrent.futures.as_completed(futs):
            r = futs[fut]
            try:
                res = fut.result()
                if is_sqs and not res.get("ok", False):
                    failures.append({"itemIdentifier": r.get("messageId", "")})
            except Exception:
                if is_sqs:
                    failures.append({"itemIdentifier": r.get("messageId", "")})

    return {"batchItemFailures": failures}

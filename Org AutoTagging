def extract_account_and_region_from_key(key: str) -> Tuple[Optional[str], Optional[str], Optional[str]]:
    parts = key.split("/")
    try:
        # AWSLogs/<OrgId>/<AccountId>/CloudTrail/<Region>/...
        return parts[1], parts[2], parts[4]
    except IndexError:
        logger.error(f"❌ Failed parsing key: {key}")
        return None, None, None

def _cred_args(creds, region: Optional[str] = None) -> dict:
    args = dict(
        aws_access_key_id=creds["AccessKeyId"],
        aws_secret_access_key=creds["SecretAccessKey"],
        aws_session_token=creds["SessionToken"],
    )
    if region:
        args["region_name"] = region
    return args

def assume_role(account_id: str, region: str) -> Optional[dict]:
    now = datetime.now(timezone.utc)
    cache_key = (account_id, region)
    cached = _CLIENT_CACHE.get(cache_key)
    if cached and cached["exp"] > now:
        return cached["clients"]

    role_arn = f"arn:aws:iam::{account_id}:role/{ROLE_NAME}"
    logger.info(f"🔐 AssumeRole into {role_arn} (region={region})")

    try:
        sts = _session.client("sts", region_name=region, config=BOTO_CFG)
        response = sts.assume_role(RoleArn=role_arn, RoleSessionName=ROLE_SESSION_NAME)
    except ClientError as e:
        logger.error(f"❌ AssumeRole failed: {e}")
        return None

    creds = response["Credentials"]

    clients = {
        "ec2": _session.client("ec2", **_cred_args(creds, region), config=BOTO_CFG),
        "s3": _session.client("s3", **_cred_args(creds, region), config=BOTO_CFG),
        # IAM is global; using us-east-1 avoids regional surprises
        "iam": _session.client("iam", **_cred_args(creds, "us-east-1"), config=BOTO_CFG),
        "rds": _session.client("rds", **_cred_args(creds, region), config=BOTO_CFG),
        "ddb": _session.client("dynamodb", **_cred_args(creds, region), config=BOTO_CFG),
        "cloudformation": _session.client("cloudformation", **_cred_args(creds, region), config=BOTO_CFG),
        "kms": _session.client("kms", **_cred_args(creds, region), config=BOTO_CFG),
        # CloudFront is global; using us-east-1
        "cloudfront": _session.client("cloudfront", **_cred_args(creds, "us-east-1"), config=BOTO_CFG),
        "eks": _session.client("eks", **_cred_args(creds, region), config=BOTO_CFG),
        "sns": _session.client("sns", **_cred_args(creds, region), config=BOTO_CFG),
        "sqs": _session.client("sqs", **_cred_args(creds, region), config=BOTO_CFG),
        "sagemaker": _session.client("sagemaker", **_cred_args(creds, region), config=BOTO_CFG),
        "autoscaling": _session.client("autoscaling", **_cred_args(creds, region), config=BOTO_CFG),
        "bedrock": _session.client("bedrock", **_cred_args(creds, region), config=BOTO_CFG),
        "bedrock_agent": _session.client("bedrock-agent", **_cred_args(creds, region), config=BOTO_CFG),
    }

    _CLIENT_CACHE[cache_key] = {"exp": creds["Expiration"], "clients": clients}
    return clients

# =========================
# S3 Select + streaming fallback
# =========================
def _build_s3_select_where() -> str:
    by_src: Dict[str, set] = {}
    for src, name in _RELEVANT:
        by_src.setdefault(src, set()).add(name)

    clauses = []
    for src, names in by_src.items():
        name_list = ",".join(f"'{n}'" for n in sorted(names))
        clauses.append(f"(s.eventSource = '{src}' AND s.eventName IN ({name_list}))")
    return " OR ".join(clauses)

def iter_relevant_events_via_s3_select(bucket: str, key: str):
    sql = f"""
    SELECT s.eventSource, s.eventName,
           s.userIdentity,
           s.eventTime, s.requestParameters, s.responseElements, s.resources, s.errorCode, s.errorMessage
    FROM S3Object[*].Records[*] s
    WHERE {_build_s3_select_where()}
    """
    try:
        resp = S3_MAIN.select_object_content(
            Bucket=bucket,
            Key=key,
            ExpressionType="SQL",
            Expression=sql,
            InputSerialization={"JSON": {"Type": "DOCUMENT"}, "CompressionType": "GZIP"},
            OutputSerialization={"JSON": {"RecordDelimiter": "\n"}},
        )
    except ClientError as e:
        logger.info(f"ℹ️ S3 Select unavailable, falling back. {e}")
        return None

    buf = b""
    for event in resp.get("Payload", []):
        if "Records" in event:
            buf += event["Records"]["Payload"]
            *lines, buf = buf.split(b"\n")
            for line in lines:
                if not line:
                    continue
                row = json.loads(line)
                yield {
                    "eventSource": row.get("eventSource"),
                    "eventName": row.get("eventName"),
                    "userIdentity": row.get("userIdentity") or {"arn": None},
                    "eventTime": row.get("eventTime"),
                    "requestParameters": row.get("requestParameters"),
                    "responseElements": row.get("responseElements"),
                    "resources": row.get("resources") or [],
                    "errorCode": row.get("errorCode"),
                    "errorMessage": row.get("errorMessage"),
                }
        elif "End" in event:
            break

def iter_relevant_events_streaming(bucket: str, key: str):
    obj = S3_MAIN.get_object(Bucket=bucket, Key=key)
    dec = JSONDecoder()
    with gzip.GzipFile(fileobj=obj["Body"]) as gz:
        reader = io.TextIOWrapper(gz, encoding="utf-8")
        chunk_iter = iter(lambda: reader.read(128 * 1024), "")
        buf = ""

        # Seek to Records array start
        while True:
            try:
                chunk = next(chunk_iter)
            except StopIteration:
                return
            buf += chunk
            idx = buf.find('"Records"')
            if idx == -1:
                buf = buf[-20:]
                continue
            lb = buf.find("[", idx)
            if lb == -1:
                buf = buf[max(idx - 2, 0):]
                continue
            buf = buf[lb + 1:]
            break

        i = 0
        while True:
            while i >= len(buf):
                try:
                    buf += next(chunk_iter)
                except StopIteration:
                    return

            while i < len(buf) and buf[i] in " \r\n\t,":
                i += 1
                if i >= len(buf):
                    try:
                        buf += next(chunk_iter)
                    except StopIteration:
                        return

            if buf[i:i+1] == "]":
                return

            try:
                obj_evt, end = dec.raw_decode(buf, i)
            except json.JSONDecodeError:
                try:
                    buf += next(chunk_iter)
                    continue
                except StopIteration:
                    return

            i = end
            if is_relevant(obj_evt):
                yield obj_evt

# =========================
# Tag helpers
# =========================
IAM_ALLOWED_VALUE_RE = re.compile(r"[^0-9A-Za-z_.:/=+\-@ ]+")

def sanitize_iam_tag_value(v: Any) -> str:
    if v is None:
        return ""
    if not isinstance(v, str):
        v = str(v)
    v = IAM_ALLOWED_VALUE_RE.sub("", v)
    v = v.strip()
    return v[:TAG_VALUE_MAX]

def filter_add_only(existing_list: List[Dict[str, str]], new_list: List[Dict[str, str]]) -> List[Dict[str, str]]:
    existing_keys = {t.get("Key") for t in (existing_list or []) if "Key" in t}
    return [t for t in (new_list or []) if t.get("Key") not in existing_keys]

def enforce_tag_limit(existing_count: int, tags_to_add: List[Dict[str, str]]) -> List[Dict[str, str]]:
    if existing_count >= TAG_LIMIT:
        return []
    room = TAG_LIMIT - existing_count
    return tags_to_add[:room]

def append_once(current: str, addition: str, sep: str = " / ") -> str:
    current = (current or "").strip()
    addition = (addition or "").strip()
    if not addition:
        return sanitize_iam_tag_value(current)
    if not current:
        return sanitize_iam_tag_value(addition)
    if addition in current:
        return sanitize_iam_tag_value(current)
    return sanitize_iam_tag_value(f"{current}{sep}{addition}")

# =========================
# created_by extraction + automation actor detection
# =========================
def _extract_best_actor(evt: dict) -> str:
    ui = evt.get("userIdentity") or {}

    v = ui.get("userName")
    if isinstance(v, str) and v.strip():
        return v.strip()

    arn = ui.get("arn")
    if isinstance(arn, str) and arn.strip():
        parts = arn.split("/")
        if parts and parts[-1].strip():
            return parts[-1].strip()

    pid = ui.get("principalId")
    if isinstance(pid, str) and pid.strip():
        if ":" in pid:
            tail = pid.split(":")[-1].strip()
            if tail:
                return tail
        return pid.strip()

    issuer_arn = (((ui.get("sessionContext") or {}).get("sessionIssuer") or {}).get("arn"))
    if isinstance(issuer_arn, str) and issuer_arn.strip():
        last = issuer_arn.split("/")[-1].strip()
        if last:
            return last

    return "unknown"

def is_automation_actor(evt: dict) -> bool:
    """
    Avoid reacting to our own TagUser/TagRole calls that would otherwise append created_by=TaggerSession.
    """
    ui = evt.get("userIdentity") or {}
    arn = ui.get("arn") or ""
    if isinstance(arn, str) and f":assumed-role/{ROLE_NAME}/" in arn:
        return True

    issuer_arn = (((ui.get("sessionContext") or {}).get("sessionIssuer") or {}).get("arn")) or ""
    if isinstance(issuer_arn, str) and issuer_arn.endswith(f":role/{ROLE_NAME}"):
        return True

    actor = _extract_best_actor(evt)
    if actor == ROLE_SESSION_NAME:
        return True

    return False

# =========================
# IAM helpers (Users, Roles, Keys)
# =========================
ACCESS_KEY_TAG_RE = re.compile(r"^(AKIA|ASIA)[A-Z0-9]{16}$")
SERVICE_SPEC_TAG_RE = re.compile(r"^ACCA[A-Z0-9]{16,}$")

def looks_like_access_key_id(k: str) -> bool:
    return isinstance(k, str) and bool(ACCESS_KEY_TAG_RE.match(k))

def looks_like_service_specific_cred_id(k: str) -> bool:
    return isinstance(k, str) and bool(SERVICE_SPEC_TAG_RE.match(k))

def looks_like_key_tag(k: str) -> bool:
    return looks_like_access_key_id(k) or looks_like_service_specific_cred_id(k)

def iam_list_user_tags(iam_client, user_name: str) -> List[Dict[str, str]]:
    try:
        return iam_client.list_user_tags(UserName=user_name).get("Tags", []) or []
    except ClientError:
        return []

def iam_tag_user(iam_client, user_name: str, tags: List[Dict[str, str]]) -> None:
    if tags:
        iam_client.tag_user(UserName=user_name, Tags=tags)

def iam_remove_user_tag_key(iam_client, user_name: str, key: str) -> None:
    if not user_name or not key:
        return
    try:
        iam_client.untag_user(UserName=user_name, TagKeys=[key])
        logger.info(f"🧹 [IAM remove] user={user_name} key={key}")
    except ClientError as e:
        if "NoSuchEntity" in str(e):
            logger.info(f"ℹ️ [IAM remove] NoSuchEntity user={user_name}; ignoring.")
            return
        logger.error(f"❌ untag_user failed user={user_name} key={key}: {e}")

def iam_add_standard_user_tags_add_only(iam_client, user_name: str, base_tags: List[Dict[str, str]]) -> None:
    existing = iam_list_user_tags(iam_client, user_name)
    to_add = filter_add_only(existing, base_tags)
    to_add = enforce_tag_limit(len(existing), to_add)
    if to_add:
        iam_tag_user(iam_client, user_name, to_add)

def iam_list_role_tags(iam_client, role_name: str) -> List[Dict[str, str]]:
    try:
        return iam_client.list_role_tags(RoleName=role_name).get("Tags", []) or []
    except ClientError:
        return []

def iam_tag_role(iam_client, role_name: str, tags: List[Dict[str, str]]) -> None:
    if tags:
        iam_client.tag_role(RoleName=role_name, Tags=tags)

def iam_add_standard_role_tags_add_only(iam_client, role_name: str, base_tags: List[Dict[str, str]]) -> None:
    existing = iam_list_role_tags(iam_client, role_name)
    to_add = filter_add_only(existing, base_tags)
    to_add = enforce_tag_limit(len(existing), to_add)
    if to_add:
        iam_tag_role(iam_client, role_name, to_add)

def iam_cleanup_orphan_access_key_tags(iam_client, user_name: str) -> None:
    """
    Authoritative cleanup for AKIA/ASIA tag keys (safe).
    Requires iam:ListAccessKeys + iam:UntagUser on the assumed role.
    """
    try:
        paginator = iam_client.get_paginator("list_access_keys")
        live = set()
        for page in paginator.paginate(UserName=user_name):
            for meta in page.get("AccessKeyMetadata", []) or []:
                akid = meta.get("AccessKeyId")
                if isinstance(akid, str) and akid:
                    live.add(akid)

        tags = iam_list_user_tags(iam_client, user_name)
        for t in tags:
            k = t.get("Key") or ""
            if looks_like_access_key_id(k) and k not in live:
                iam_remove_user_tag_key(iam_client, user_name, k)
    except ClientError as e:
        if "NoSuchEntity" in str(e):
            return
        logger.error(f"❌ orphan access-key cleanup failed user={user_name}: {e}")

def iam_evict_one_accc_tag_if_needed(iam_client, user_name: str) -> bool:
    """
    Best-effort: if we hit the 50-tag limit due to missing DeleteServiceSpecificCredential events,
    evict ONE ACCA* tag key (only ACCA, never business tags) to free room.
    """
    if not EVICT_ACCA_ON_LIMIT:
        return False

    tags = iam_list_user_tags(iam_client, user_name)
    acca_keys = sorted([t.get("Key") for t in tags if looks_like_service_specific_cred_id(t.get("Key") or "")])

    if not acca_keys:
        return False

    victim = acca_keys[0]  # deterministic
    iam_remove_user_tag_key(iam_client, user_name, victim)
    logger.warning(f"⚠️ [IAM] Evicted ACCA tag key={victim} for user={user_name} to free tag capacity")
    return True

def iam_append_created_by_for_key_tag(iam_client, user_name: str, key: str, actor: str) -> None:
    """
    Append-only on the *credential-id tag key* (AKIA/ASIA/ACCA):
      - ensure created_by=... exists in the VALUE
      - DO NOT append created_time=... (per your request)
    """
    if not user_name or not key:
        return

    actor = sanitize_iam_tag_value(actor) or "unknown"
    suffix = f"created_by={actor}"

    existing = iam_list_user_tags(iam_client, user_name)
    existing_map = {t.get("Key"): (t.get("Value") or "") for t in existing if "Key" in t}

    # Need room for a new key?
    if key not in existing_map and len(existing_map) >= TAG_LIMIT:
        if looks_like_access_key_id(key):
            iam_cleanup_orphan_access_key_tags(iam_client, user_name)
            existing = iam_list_user_tags(iam_client, user_name)
            existing_map = {t.get("Key"): (t.get("Value") or "") for t in existing if "Key" in t}
        elif looks_like_service_specific_cred_id(key):
            iam_evict_one_accc_tag_if_needed(iam_client, user_name)
            existing = iam_list_user_tags(iam_client, user_name)
            existing_map = {t.get("Key"): (t.get("Value") or "") for t in existing if "Key" in t}

    if key not in existing_map and len(existing_map) >= TAG_LIMIT:
        logger.warning(f"⚠️ [IAM] Tag limit reached for user={user_name}; cannot add key={key}")
        return

    cur_val = existing_map.get(key, "")

    # Don’t append if already present (any created_by)
    if "created_by=" in cur_val:
        return

    new_val = append_once(cur_val, suffix, sep=" / ")
    if new_val == cur_val:
        return

    try:
        iam_tag_user(iam_client, user_name, [{"Key": key, "Value": new_val}])
        logger.info(f"🏷️ [IAM key-tag append] user={user_name} key={key} value={new_val}")
    except ClientError as e:
        logger.error(f"❌ TagUser failed user={user_name} key={key}: {e}")

def parse_tags_from_request(req: dict) -> List[Dict[str, str]]:
    """
    CloudTrail shapes:
      requestParameters.tags: [{"key":"..","value":".."}, ...]
      requestParameters.tags: [{"Key":"..","Value":".."}, ...]
      requestParameters.tags: {"key":"..","value":".."}
    """
    tags = (req or {}).get("tags")
    if isinstance(tags, dict):
        k = tags.get("key") or tags.get("Key")
        v = tags.get("value") or tags.get("Value")
        if isinstance(k, str):
            return [{"Key": k, "Value": str(v or "")}]
        return []

    if not isinstance(tags, list):
        return []

    out: List[Dict[str, str]] = []
    for t in tags:
        if not isinstance(t, dict):
            continue
        k = t.get("key") or t.get("Key")
        v = t.get("value") or t.get("Value")
        if isinstance(k, str):
            out.append({"Key": k, "Value": str(v or "")})
    return out


def is_relevant(evt: dict) -> bool:
    return (evt.get("eventSource"), evt.get("eventName")) in _RELEVANT

def is_failed_event(evt: dict) -> bool:
    return bool(evt.get("errorCode") or evt.get("errorMessage"))

# =========================
# Path helper
# =========================
def get_path(obj: Any, path: str) -> Any:
    cur = obj
    for p in path.split("."):
        if not isinstance(cur, dict):
            return None
        cur = cur.get(p)
    return cur

# =========================
# EC2: skip Spot / ASG / EKS-managed instances
# =========================
def should_tag_ec2_instance(evt: dict) -> bool:
    req = evt.get("requestParameters") or {}

    # Skip Spot
    if get_path(req, "instanceMarketOptions.marketType") == "spot":
        return False

    # Skip ASG-launched instances
    if isinstance(req.get("autoScalingGroupName"), str) and req.get("autoScalingGroupName"):
        return False

    # Skip EKS-managed nodes
    ui = evt.get("userIdentity") or {}
    if ui.get("invokedBy") == "eks.amazonaws.com":
        return False

    if "eks" in (req.get("clientToken") or ""):
        return False

    return True


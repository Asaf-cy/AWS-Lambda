def extract_resource_ids_for_mapping(evt: dict, account_id: str) -> List[str]:
    cfg = RESOURCE_MAPPINGS.get((evt.get("eventSource"), evt.get("eventName")))
    if not cfg:
        return []

    if cfg["type"] == "list":
        items = get_path(evt, cfg["list_path"])
        if not isinstance(items, list):
            return []
        out: List[str] = []
        for it in items:
            if isinstance(it, dict):
                rid = it.get(cfg["id_key"])
                if isinstance(rid, str) and rid:
                    out.append(rid)
        return out

    for p in cfg.get("paths", []):
        v = get_path(evt, p)
        if isinstance(v, str) and v:
            return [v]

    if cfg["service"] == "cloudfront":
        dist_id = ""
        for p in cfg.get("id_fallback_paths", []):
            v = get_path(evt, p)
            if isinstance(v, str) and v:
                dist_id = v
                break
        if dist_id and account_id:
            return [f"arn:aws:cloudfront::{account_id}:distribution/{dist_id}"]

    return []

